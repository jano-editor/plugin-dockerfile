{
  "name": "jano-plugin-dockerfile",
  "version": "1.0.0",
  "description": "Dockerfile syntax highlighting and formatting for jano editor.",
  "homepage": "https://github.com/jano-editor/jano-plugin-dockerfile",
  "license": "MIT",
  "author": "jano-editor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jano-editor/jano-plugin-dockerfile.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@jano-editor/plugin-types": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
